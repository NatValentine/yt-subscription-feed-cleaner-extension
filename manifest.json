{
  "manifest_version": 2,
  "name": "YT Subscription Feed Cleaner",
  "version": "2.0",
  "description": "Hide Shorts, featured sections and filter videos by keywords.",

  "permissions": [
    "storage",
    "*://www.youtube.com/*"
  ],

  "browser_action": {
    "default_title": "YT Subscription Feed Cleaner",
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"]
    }
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "ytsubsfeedcleaner@natvalentine",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}